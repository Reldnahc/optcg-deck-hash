{
  "name": "optcg-deck-hash",
  "version": "0.1.0",
  "description": "OPTCG deck hash codec with bundled dictionary snapshot and optional API refresh",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "sync:dictionary": "node scripts/sync-dictionary.mjs",
    "test": "npm run build && node test/codec.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3"
  }
}
